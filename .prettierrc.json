{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": true,
  "singleQuote": true,
  "printWidth": 120,
  "bracketSameLine": true,
  "htmlWhitespaceSensitivity": "ignore",
  "singleAttributePerLine": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "vueIndentScriptAndStyle": true,
  "tabWidth": 2,
  "useTabs": false
}
